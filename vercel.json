{
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*\\.html)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, s-maxage=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*\\.csv)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, s-maxage=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*\\.json)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, s-maxage=0, must-revalidate"
                }
            ]
        }
    ]
}